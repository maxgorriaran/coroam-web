# Public Supabase client (browser-safe — anon key only, never service_role)
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your_anon_key

# Optional: override MapLibre style JSON URL (defaults to CARTO Positron — light flat map)
# VITE_MAPLIBRE_STYLE_URL=https://basemaps.cartocdn.com/gl/positron-gl-style/style.json
